{
  "manifest_version": 3,
  "name": "Endfield Third Brige",
  "version": "0.4.2",
  "description": "Bridge Third-Party OAuth callback to Endfield skport backend flow.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [
    "*://web-api.gryphline.com/*",
    "*://as.gryphline.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3018/*",
        "https://end.shallow.ink/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Endfield Third-Party Bridge",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png"
    }
  }
}
